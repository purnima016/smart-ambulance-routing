<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/emergency_red"
    android:padding="40dp">

    <!-- App Name - Keeping your original italic cursive style -->
    <TextView
        android:id="@+id/appName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"
        android:text="Smart Ambulance Routing"
        android:textColor="@color/white"
        android:textSize="30sp"
        android:textStyle="italic"
        android:fontFamily="cursive"
        android:alpha="0" />

    <!-- White Circle Container -->
    <LinearLayout
        android:id="@+id/whiteCircle"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_centerInParent="true"
        android:background="@drawable/logo_rounded_bg"
        android:gravity="center"
        android:orientation="vertical"
        android:alpha="0">

        <!-- Ambulance Icon -->
        <TextView
            android:id="@+id/ambulanceIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🚑"
            android:textSize="90sp"
            android:alpha="0" />

    </LinearLayout>

    <!-- Loading Progress -->
    <ProgressBar
        android:id="@+id/loadingProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:indeterminateTint="@color/white"
        android:alpha="0" />

    <TextView
        android:id="@+id/loadingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_above="@id/loadingProgress"
        android:layout_marginBottom="20dp"
        android:text="🚨 Initializing Emergency System...🚨 "
        android:textColor="@color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:alpha="0" />

</RelativeLayout>