<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    android:elevation="4dp"
    app:cardCornerRadius="12dp"
    app:cardUseCompatPadding="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="#FFFFFF">

        <!-- Hospital Name -->
        <TextView
            android:id="@+id/tvHospitalName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hospital Name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="8dp" />

        <!-- Specialties -->
        <TextView
            android:id="@+id/tvSpecialties"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Specialties"
            android:textSize="14sp"
            android:textColor="#455A64"
            android:layout_marginBottom="12dp" />

        <!-- BLOOD GROUP STATUS - Lighter Green Background -->
        <TextView
            android:id="@+id/tvBloodStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🩸 Blood A+: AVAILABLE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="12dp"
            android:background="#F1F8E9"
            android:textColor="#2E7D32"
            android:padding="12dp"
            android:visibility="visible" />

        <!-- Details Row 1: Distance and Response Time -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <!-- Distance -->
            <TextView
                android:id="@+id/tvDistance"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📍 0.0 km"
                android:textSize="13sp"
                android:textColor="#546E7A"
                android:textStyle="bold" />

            <!-- Response Time -->
            <TextView
                android:id="@+id/tvResponseTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⏱️ 0 min"
                android:textSize="13sp"
                android:textColor="#546E7A"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Details Row 2: Beds and Rating -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <!-- Available Beds -->
            <TextView
                android:id="@+id/tvAvailableBeds"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="🛏️ 0 beds"
                android:textSize="13sp"
                android:textColor="#546E7A"
                android:textStyle="bold" />

            <!-- Rating -->
            <TextView
                android:id="@+id/tvRating"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⭐ 0.0"
                android:textSize="13sp"
                android:textColor="#546E7A"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Navigate Button -->
        <Button
            android:id="@+id/btnNavigate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SELECT AND NAVIGATE"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:padding="14dp"
            android:textSize="14sp" />

    </LinearLayout>

</androidx.cardview.widget.CardView>